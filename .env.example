# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/crm_hcp_db

# Groq API Setup (Mandatory for LangGraph LLM Inference)
# Get a free key from https://console.groq.com
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_PRIMARY_MODEL=gemma2-9b-it
GROQ_SECONDARY_MODEL=llama-3.3-70b-versatile

# Backend Security & CORS
SECRET_KEY=crm_enterprise_secret_key_change_in_production
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Frontend API URL
VITE_API_BASE_URL=http://localhost:8000/api/v1
